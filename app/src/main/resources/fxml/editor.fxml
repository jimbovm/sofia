<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TitledPane?>

<TitledPane animated="false" fx:id="editor" prefHeight="768.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/17"
	xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.jimbovm.sofia.fxml.EditorController">
	<content>
		<SplitPane dividerPositions="0.5"
			orientation="VERTICAL" fx:id="editorSplitPane">
			<items>
				<fx:include source="editor_toolbar.fxml" />
				<ScrollPane pannable="true"
					vbarPolicy="ALWAYS" fx:id="editorScrollPane">
					<content>
						<Group fx:id="canvasContainer" />
					</content>
					<cursor>
						<Cursor
							fx:constant="CROSSHAIR" />
					</cursor>
				</ScrollPane>
			</items>
		</SplitPane>
	</content>
</TitledPane>